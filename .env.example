# --- Entorno Django ---
# development (local) | production (App Platform / servidor)
DJANGO_ENV=development
DJANGO_SECRET_KEY=
DJANGO_DEBUG=true
ALLOWED_HOSTS=127.0.0.1,localhost
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Producción (DigitalOcean App Platform)
# DJANGO_ENV=production
# DJANGO_DEBUG=false
# DJANGO_SECRET_KEY=<generar clave larga aleatoria>
# ALLOWED_HOSTS=tu-api.ondigitalocean.app
# CORS_ALLOWED_ORIGINS=https://tu-front.ondigitalocean.app
# DJANGO_SECURE_SSL_REDIRECT=false
# DJANGO_OPENAPI=false
# MYSQL_SSL=true

# --- MySQL (local o DigitalOcean Managed Database) ---
MYSQL_DB=sistema_prestamos
MYSQL_USER=root
MYSQL_PASSWORD=123456
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306

# DigitalOcean Managed MySQL (ejemplo):
# MYSQL_DB=defaultdb
# MYSQL_USER=doadmin
# MYSQL_PASSWORD=<desde panel DO>
# MYSQL_HOST=db-mysql-nyc3-xxxxx.db.ondigitalocean.com
# MYSQL_PORT=25060
# MYSQL_SSL=true

# --- Archivos subidos (documentos, PDF) ---
# En App Platform montar volumen en esta ruta:
# MEDIA_ROOT=/app/media

# --- JWT (opcional; valores por defecto en settings) ---
# JWT_ACCESS_MINUTES=60
# JWT_REFRESH_DAYS=7
# JWT_ROTATE_REFRESH=true

# --- Throttle login producción (opcional) ---
# THROTTLE_LOGIN=10/min
# THROTTLE_LOGIN_USER=30/min

# --- Admin Django (solo si lo necesitas en producción) ---
# DJANGO_ENABLE_ADMIN=false
# DJANGO_ADMIN_URL=gestion-interna-findeco/
